[user]
    name = Adam Gärdelöv
    email = adam.gardelov@wint.se
[url "git@github.com:"]
    insteadOf = https://github.com/
[merge]
    commit = no-edit
    conflictStyle = zdiff3
[core]
    autocrlf = input
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    dark = true
    side-by-side = true
[credential "https://github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
    helper =
    helper = !/usr/bin/gh auth git-credential
[push]
    autoSetupRemote = true
[diff]
    colorMoved = default
[alias]
    diffall = "!git add -N . && git diff; git reset -q"
